{
  "name": "emdash-cloudflare-email",
  "version": "0.2.0",
  "description": "EmDash CMS plugin: deliver system email (magic link / invite / password reset) via the native Cloudflare Email Sending Workers binding. No API token required.",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./sandbox": {
      "import": "./dist/sandbox-entry.mjs",
      "types": "./dist/sandbox-entry.d.mts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/sandbox-entry.ts --format esm --dts --clean",
    "dev": "tsdown src/index.ts src/sandbox-entry.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "emdash",
    "emdash-plugin",
    "cms",
    "cloudflare",
    "cloudflare-workers",
    "email",
    "email-sending",
    "transactional-email"
  ],
  "license": "MIT",
  "author": "Yushi Matsui <https://github.com/tmyuu>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tmyuu/emdash-cloudflare-email.git"
  },
  "bugs": {
    "url": "https://github.com/tmyuu/emdash-cloudflare-email/issues"
  },
  "homepage": "https://github.com/tmyuu/emdash-cloudflare-email#readme",
  "peerDependencies": {
    "emdash": ">=0.19.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260424.1",
    "emdash": "^0.19.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
